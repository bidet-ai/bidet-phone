<?xml version="1.0" encoding="utf-8"?>
<!--
  v21 (2026-05-13): unified soft-blue launcher background.

  The brain-over-water Bidet AI icon (in ic_launcher_foreground_letter.xml) already includes
  its own white-rounded-square + blue-water-splash artwork on a transparent canvas, so the
  adaptive-icon background underneath just needs to be a neutral fill that matches the
  splash's hue and shows through cleanly when a launcher applies a round/squircle mask. Soft
  blue (#FFE6F0FA — the same value the main flavor uses) is the match.

  Previously this drawable painted Material Green 700 (#388E3C) so the "G" letter glyph
  would read against a green background; with the brain artwork as the foreground, the
  letter has been retired and the green background no longer serves a purpose.
-->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">
  <path
      android:fillColor="#FFE6F0FA"
      android:pathData="M0,0h108v108h-108z" />
</vector>
